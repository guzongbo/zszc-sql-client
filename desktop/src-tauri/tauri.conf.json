{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZSZC SQL Client",
  "version": "0.1.0",
  "identifier": "com.wxguzb.zszc-sql-client",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ZSZC SQL Client",
        "width": 1280,
        "height": 840,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
