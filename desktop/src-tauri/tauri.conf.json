{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZSZC SQL Client",
  "version": "0.1.0",
  "identifier": "com.wxguzb.zszc-sql-client",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "node ../scripts/ensure-frontend-build.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ZSZC SQL Client",
        "width": 1280,
        "height": 840,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icons/32.png",
      "../build/icons/128.png",
      "../build/icons/256.png",
      "../build/icons/icon.icns",
      "../build/icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  }
}
